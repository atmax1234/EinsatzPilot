{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "ignoreDeprecations": "6.0",
    "strict": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@einsatzpilot/config": ["packages/config/src"],
      "@einsatzpilot/schemas": ["packages/schemas/src"],
      "@einsatzpilot/types": ["packages/types/src"],
      "@einsatzpilot/utils": ["packages/utils/src"]
    }
  }
}
