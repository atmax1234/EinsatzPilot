{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "rootDir": "../..",
    "rootDirs": ["src", "../../packages/types/src", "../../packages/schemas/src", "../../packages/config/src", "../../packages/utils/src"],
    "types": ["node"],
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "outDir": "dist"
  },
  "include": ["src/**/*.ts", "src/**/*.d.ts", "prisma.config.ts"],
  "exclude": ["node_modules", "dist"]
}
